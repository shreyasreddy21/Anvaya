# Frontend build-time configuration (Vite).
# Copy to .env and set for your deployment. Used at BUILD time.

# Base URL of the deployed backend API (no trailing slash).
REACT_APP_API_URL=http://localhost:4000

# Optional AI progress-summary feature. Leave 'false' (or unset) to hide the UI
# and never call the AI endpoint. Only set 'true' when the backend has
# ENABLE_AI_SUMMARIES=true and a valid ANTHROPIC_API_KEY.
REACT_APP_ENABLE_AI_SUMMARIES=false

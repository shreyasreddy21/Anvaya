# ==============================================================================
# Anvaya / JoyVerse -- Production Environment Variables
#
# INSTRUCTIONS:
#   1. Copy this file:  cp .env.production.example .env.production
#   2. Fill in every value marked  <- CHANGE THIS
#   3. Never commit .env.production to git
#   4. Pass to docker compose:  docker compose --env-file .env.production up -d
# ==============================================================================

# -- Backend -------------------------------------------------------------------

# MongoDB Atlas connection string  <- CHANGE THIS
# Format: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority
# Get it from: Atlas dashboard -> Connect -> Drivers -> Node.js
MONGO_URI=mongodb+srv://YOURUSER:YOURPASSWORD@cluster0.xxxxx.mongodb.net/joyverse?retryWrites=true&w=majority

# JWT secret -- MUST be at least 64 random characters  <- CHANGE THIS
# Generate:  node -e "require('crypto').randomBytes(64).toString('hex')"
#       or:  openssl rand -hex 64
JWT_SECRET=CHANGE_ME_generate_with_openssl_rand_hex_64_and_paste_here

# JWT token expiry
# 8h = one school day session | 24h = full day | 7d = week
JWT_EXPIRES_IN=8h

# Comma-separated list of allowed frontend origins (no trailing slash)  <- CHANGE THIS
# Example:  https://joyverse.yourdomain.com,https://www.yourdomain.com
CORS_ORIGINS=https://yourdomain.com

# Node environment -- always "production" here
NODE_ENV=production

# Port the Express backend listens on inside the container
PORT=4000

# -- AI Progress Summaries (OPTIONAL feature, OFF by default) ------------------
# This feature is fully optional and disabled unless you explicitly turn it on.
# Leaving these as-is means the app builds, deploys, and runs with no API key and
# no errors — the summary panel simply shows "currently turned off".
#
# To ENABLE it you need BOTH of the following:
ENABLE_AI_SUMMARIES=false
# Anthropic API key — only needed when ENABLE_AI_SUMMARIES=true.
# Get it from: https://console.anthropic.com/ -> API Keys
ANTHROPIC_API_KEY=

# -- Frontend (build-time, passed via Docker build-arg) -----------------------

# Full URL of the backend API as seen by the browser  <- CHANGE THIS
# Should point to your nginx reverse proxy domain root (no trailing slash, no /api)
REACT_APP_API_URL=https://yourdomain.com

# Show the AI summary UI in the frontend (build-time). Leave 'false' (or unset)
# to keep the feature hidden and prevent the browser from calling the AI endpoint.
# Set to 'true' only alongside the two backend vars above.
REACT_APP_ENABLE_AI_SUMMARIES=false
